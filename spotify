#!/bin/bash
# Spotify CLI Wrapper - Auto-loads credentials

# Resolve real path (follow symlinks)
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"
CREDENTIALS_FILE="/srv/clawd-share/Andreas/Spotify.txt"

# Pass through help/version flags directly
if [[ "$1" == "--help" || "$1" == "-h" || "$1" == "--version" || "$1" == "-v" || "$1" == "help" ]]; then
    exec python3 "$SCRIPT_DIR/scripts/spotify.py" "$@"
fi

# Load credentials from structured file
if [ -f "$CREDENTIALS_FILE" ]; then
    # Robust parser: find key, get next non-empty line
    export SPOTIFY_CLIENT_ID=$(awk '/^Client ID$/{getline; while($0=="")getline; print; exit}' "$CREDENTIALS_FILE" | tr -d '[:space:]')
    export SPOTIFY_CLIENT_SECRET=$(awk '/^Client Secret$/{getline; while($0=="")getline; print; exit}' "$CREDENTIALS_FILE" | tr -d '[:space:]')

    if [ -z "$SPOTIFY_CLIENT_ID" ] || [ -z "$SPOTIFY_CLIENT_SECRET" ]; then
        echo "❌ Credentials file found but Client ID or Secret is empty: $CREDENTIALS_FILE"
        exit 1
    fi
else
    echo "❌ Credentials file not found: $CREDENTIALS_FILE"
    exit 1
fi

# Run spotify.py with all arguments
exec python3 "$SCRIPT_DIR/scripts/spotify.py" "$@"
